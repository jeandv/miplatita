# PostgreSQL connection string (local or Neon)
# Local: postgresql://postgres:postgres@localhost:5432/miplatita
# Neon:  postgresql://user:password@host.neon.tech/miplatita?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/miplatita

# Better Auth secret (generate a random 32+ char string)
BETTER_AUTH_SECRET=your-secret-here

# Better Auth base URL
BETTER_AUTH_URL=http://localhost:3001
